# syntax=docker/dockerfile:1

FROM --platform=$BUILDPLATFORM golang:1.25-alpine AS build
WORKDIR /src

ARG TARGETOS=linux
ARG TARGETARCH=amd64

COPY go.mod go.sum ./
RUN go mod download

COPY cmd ./cmd
COPY internal ./internal

RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH go build -trimpath -ldflags="-s -w" -o /out/cluster-agent ./cmd/cluster-agent

FROM alpine:3.22
RUN apk add --no-cache ca-certificates kubectl
COPY --from=build /out/cluster-agent /usr/local/bin/cluster-agent
USER 65532:65532
ENTRYPOINT ["/usr/local/bin/cluster-agent"]
